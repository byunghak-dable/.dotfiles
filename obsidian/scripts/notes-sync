#!/bin/zsh
# second-brain vault를 GitHub에 sync (백그라운드 — Stop hook 블로킹 방지)
VAULT="$HOME/second-brain"

(
  cd "$VAULT" || exit 1

  # 원격 변경사항 먼저 pull (conflict 방지)
  git pull --rebase origin main 2>/dev/null

  # 로컬 변경사항 있으면 push
  if [ -n "$(git status --porcelain)" ]; then
    git add .
    git commit -m "sync: $(date '+%Y-%m-%d %H:%M')"
    git push origin main
  fi
) &>/dev/null &
disown

exit 0
