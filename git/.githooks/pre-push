#!/bin/bash
# 글로벌 pre-push hook: README.md 업데이트 필요 여부 검토 및 자동 수정
set -uo pipefail

SCRIPTS_DIR="$(dirname "$0")/scripts"
TMPDIR_HOOK=$(mktemp -d)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

# skip 메커니즘: SKIP_PREPUSH=1 git push 또는 git push --no-verify
if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "⏭️  Pre-push hook skipped (SKIP_PREPUSH=1)"
  exit 0
fi

# claude CLI 존재 확인
if ! command -v claude &>/dev/null; then
  echo "⚠️  claude CLI not found. Skipping pre-push hook."
  exit 0
fi

# stdin에서 push 정보 읽기: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  # 삭제 push는 무시
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # 새 브랜치인 경우 remote에 없으므로 main/master 기준으로 diff
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@') || true
    if [ -z "$base_branch" ]; then
      base_branch=$(git branch -r | grep -E 'origin/(main|master)' | head -1 | sed 's@.*origin/@@' | tr -d ' ') || true
    fi
    if [ -z "$base_branch" ]; then
      echo "⚠️  Cannot determine base branch. Skipping README check."
      continue
    fi
    range="origin/${base_branch}..${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi

  # diff/log를 임시 파일에 저장 (ARG_MAX 회피)
  diff_file="$TMPDIR_HOOK/diff.patch"
  log_file="$TMPDIR_HOOK/commits.log"

  git diff "$range" > "$diff_file" 2>/dev/null || continue
  if [ ! -s "$diff_file" ]; then
    continue
  fi

  git log --oneline "$range" > "$log_file" 2>/dev/null || continue

  echo ""
  echo "📋 Checking README.md... (${local_ref})"

  # README 업데이트 필요 여부 검토
  readme_check_file="$TMPDIR_HOOK/readme_check"
  bash "$SCRIPTS_DIR/check-readme.sh" "$diff_file" "$log_file" "$range" --check-only > "$readme_check_file" 2>&1
  readme_exit=$?

  cat "$readme_check_file"

  # README 업데이트 필요 판정 시 → 자동 수정
  if [ $readme_exit -eq 2 ]; then
    echo ""
    bash "$SCRIPTS_DIR/check-readme.sh" "$diff_file" "$log_file" "$range" --update
    echo ""
    echo "⚠️  README.md가 업데이트되어 새 커밋이 생성되었습니다."
    echo "   다시 push 해주세요: git push"
    exit 1
  fi

done

exit 0
