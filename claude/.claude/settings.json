{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Glob",
      "Grep",
      "Task",
      "ToolSearch",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git show)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v *)",
      "Bash(git branch --list *)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git rev-parse *)",
      "Bash(git rev-parse)",
      "Bash(git ls-files *)",
      "Bash(git ls-files)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(* --help)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(date)",
      "Bash(gh pr view *)",
      "Bash(gh pr view)",
      "Bash(gh pr list *)",
      "Bash(gh pr list)",
      "Bash(gh issue view *)",
      "Bash(gh issue view)",
      "Bash(gh issue list *)",
      "Bash(gh issue list)",
      "Bash(npm run *)",
      "Bash(pnpm run *)",
      "Bash(npm list *)",
      "Bash(npm list)",
      "Bash(pnpm list *)",
      "Bash(pnpm list)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.npmrc)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/**)",
      "Read(//**/*.pem)",
      "Read(//**/*.key)",
      "Read(//**/credentials.json)",
      "Read(//**/service-account*.json)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-file.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'node_bin=$(volta which node 2>/dev/null || which node) && \"$node_bin\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
