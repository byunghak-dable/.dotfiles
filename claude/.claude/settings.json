{
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-file.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'node_bin=$(volta which node 2>/dev/null || which node) && \"$node_bin\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "serena@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,

    "lua-lsp@claude-plugins-official": false,
    "jdtls-lsp@claude-plugins-official": false,
    "kotlin-lsp@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,

    "code-review@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true
}
